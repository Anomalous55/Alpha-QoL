+                } else if (!isFuelItem && isSmeltableItem) {
+                    success = this.mergeItemStack(stack, 0, 1, false);
+                } else if (isFuelItem && isSmeltableItem) {
+                    success = this.mergeItemStack(stack, 0, 1, false);

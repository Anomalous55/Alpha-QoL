+                if (!success) {
+                    success = this.mergeItemStack(stack, 10, totalSlots - 9, false);
+                }
+            } else {
+                success = this.moveBetweenPlayerSlots(clickedSlot, stack, absoluteIndex, 10, totalSlots);
+            }
+        }
